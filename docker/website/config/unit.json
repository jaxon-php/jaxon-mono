{
    "listeners": {
        "*:80": {
            "pass": "routes"
        }
    },

    "routes": [
        {
            "match": {
                "uri": "/js/dialogs/*"
            },
            "action": {
                "share": "/var/www/dialogs/js$uri"
            }
        },
        {
            "match": {
                "uri": "/examples/*"
            },
            "action": {
                "share": "/var/www/examples/public$uri",
                "fallback": {
                    "pass": "applications/examples"
                }
            }
        },
        {
            "match": {
                "uri": ["/assets/*", "/images/*", "/user/plugins/*"]
            },
            "action": {
                "share": "/var/www/website$uri"
            }
        },
        {
            "match": {
                "uri": "!/not-index.php"
            },
            "action": {
                "share": "/var/www/website/public$uri",
                "fallback": {
                    "pass": "applications/website"
                }
            }
        }
    ],

    "applications": {
        "website": {
            "type": "php",
            "root": "/var/www/website/public/",
            "script": "index.php"
        },
        "examples": {
            "type": "php",
            "root": "/var/www/examples/public/"
        }
    }
}
